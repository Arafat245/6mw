\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Home walking-bout characteristics by cohort. Left: violin plot of the longest sustained bout per subject where POMS subjects have fewer long sustained bouts. Middle: violin plot of the per-subject 90th percentile of bout intensity. Right: pooled bout-duration survival curve with 95\% bootstrap CI.\relax }}{10}{figure.caption.5}\protected@file@percent }
\newlabel{fig:bout_overview}{{2}{10}{Home walking-bout characteristics by cohort. Left: violin plot of the longest sustained bout per subject where POMS subjects have fewer long sustained bouts. Middle: violin plot of the per-subject 90th percentile of bout intensity. Right: pooled bout-duration survival curve with 95\% bootstrap CI.\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Spearman correlations between accelerometry features and 6MWD in the full cohort (All), the POMS subgroup, and the healthy subgroup. Clinic features (left) and home features (right) are shown side by side. Gait intensity and tempo features dominate the clinic side. Home correlations are smaller but directionally consistent. Significance stars use raw $p$-values: *$p<0.05$, **$p<0.01$, ***$p<0.001$.\relax }}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:corr_6mwd}{{3}{10}{Spearman correlations between accelerometry features and 6MWD in the full cohort (All), the POMS subgroup, and the healthy subgroup. Clinic features (left) and home features (right) are shown side by side. Gait intensity and tempo features dominate the clinic side. Home correlations are smaller but directionally consistent. Significance stars use raw $p$-values: *$p<0.05$, **$p<0.01$, ***$p<0.001$.\relax }{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}RQ3: Correlation Between Clinic and Home Wearable Features}{11}{subsection.4.3}\protected@file@percent }
\newlabel{sec:rq3}{{4.3}{11}{RQ3: Correlation Between Clinic and Home Wearable Features}{subsection.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Spearman cross-correlation of five matched Gait features between clinic and home settings. Rows are clinic features; columns are their 90th-percentile home counterparts. Each panel shows one cohort group (All, POMS, Healthy). Diagonal cells are the direct clinic-to-home matches; off-diagonal cells show cross-feature spillover. The positive diagonal cluster in the full-cohort and POMS panels shows that the supervised 6MWT tracks the upper decile of free-living walking rather than the median.\relax }}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:clinic_home_corr}{{4}{11}{Spearman cross-correlation of five matched Gait features between clinic and home settings. Rows are clinic features; columns are their 90th-percentile home counterparts. Each panel shows one cohort group (All, POMS, Healthy). Diagonal cells are the direct clinic-to-home matches; off-diagonal cells show cross-feature spillover. The positive diagonal cluster in the full-cohort and POMS panels shows that the supervised 6MWT tracks the upper decile of free-living walking rather than the median.\relax }{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}RQ4: Correlations with Clinical Scores}{11}{subsection.4.4}\protected@file@percent }
\newlabel{sec:rq4}{{4.4}{11}{RQ4: Correlations with Clinical Scores}{subsection.4.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Spearman correlations between clinic accelerometry features and clinical scores in the POMS subgroup ($n=38$). Rows are the top 10 features whose sign matches gait-literature expectations. CWT irregularity and high-frequency energy rise with fatigue (MFIS) and depression (BDI) scores.\relax }}{12}{figure.caption.8}\protected@file@percent }
\newlabel{fig:clin_corr_clinic}{{5}{12}{Spearman correlations between clinic accelerometry features and clinical scores in the POMS subgroup ($n=38$). Rows are the top 10 features whose sign matches gait-literature expectations. CWT irregularity and high-frequency energy rise with fatigue (MFIS) and depression (BDI) scores.\relax }{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}RQ5: 6MWD Prediction Performance}{12}{subsection.4.5}\protected@file@percent }
\newlabel{sec:rq5}{{4.5}{12}{RQ5: 6MWD Prediction Performance}{subsection.4.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Spearman correlations between home accelerometry features and clinical scores in the POMS subgroup ($n=38$). Two axes explain most of the signal: shorter and less varied walking bouts, and slower and more variable stride timing.\relax }}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:clin_corr_home}{{6}{13}{Spearman correlations between home accelerometry features and clinical scores in the POMS subgroup ($n=38$). Two axes explain most of the signal: shorter and less varied walking bouts, and slower and more variable stride timing.\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces 6MWD prediction MAE by model for clinic (blue) and home (red) settings. Error bars are 95\% percentile bootstrap confidence intervals. Linear models dominate in the clinic (ElasticNet 30.2\,m, Ridge 31.2\,m, Lasso 33.2\,m); the home setting is flatter across models, with home MAEs clustered in a narrow 55--66\,m band while clinic MAEs span a wider 30--56\,m range. The clinic-to-home gap is roughly 20--25\,m for the best linear models and shrinks for less-accurate regressors, indicating that the home ceiling is set by the free-living data rather than the model choice.\relax }}{13}{figure.caption.10}\protected@file@percent }
\newlabel{fig:model_bar}{{7}{13}{6MWD prediction MAE by model for clinic (blue) and home (red) settings. Error bars are 95\% percentile bootstrap confidence intervals. Linear models dominate in the clinic (ElasticNet 30.2\,m, Ridge 31.2\,m, Lasso 33.2\,m); the home setting is flatter across models, with home MAEs clustered in a narrow 55--66\,m band while clinic MAEs span a wider 30--56\,m range. The clinic-to-home gap is roughly 20--25\,m for the best linear models and shrinks for less-accurate regressors, indicating that the home ceiling is set by the free-living data rather than the model choice.\relax }{figure.caption.10}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces 6MWD prediction performance by feature set and setting. Ridge regression with leave-one-out cross-validation. Values are mean [95\% bootstrap CI] from 2{,}000 resamples. Best per setting is in \textbf  {bold}.\relax }}{14}{table.caption.11}\protected@file@percent }
\newlabel{tab:results}{{4}{14}{6MWD prediction performance by feature set and setting. Ridge regression with leave-one-out cross-validation. Values are mean [95\% bootstrap CI] from 2{,}000 resamples. Best per setting is in \textbf {bold}.\relax }{table.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Per-cohort prediction performance for the two best feature sets. All values are mean [95\% bootstrap CI].\relax }}{14}{table.caption.12}\protected@file@percent }
\newlabel{tab:error}{{5}{14}{Per-cohort prediction performance for the two best feature sets. All values are mean [95\% bootstrap CI].\relax }{table.caption.12}{}}
