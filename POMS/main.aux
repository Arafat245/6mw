\newlabel{sec:supp}{{6}{20}{Supplementary Figures}{section*.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Supplementary Figure S1. (a) Device wear time over the seven-day home monitoring period, shown as violin plots with jittered subject points for POMS and healthy controls. Median wear time is 59 hours for POMS and 53 hours for healthy controls, with no significant group difference (Mann-Whitney $U$, $p = 0.19$). (b) Per-subject scatter of number of walking bouts against median bout duration. Point size is scaled by 6MWD. Subjects with more bouts and longer median bout durations tend to have longer 6MWD. Axes use log scales to accommodate the wide range of bout counts and durations.\relax }}{20}{figure.caption.15}\protected@file@percent }
\newlabel{fig:supp_wear_median_bout}{{8}{20}{Supplementary Figure S1. (a) Device wear time over the seven-day home monitoring period, shown as violin plots with jittered subject points for POMS and healthy controls. Median wear time is 59 hours for POMS and 53 hours for healthy controls, with no significant group difference (Mann-Whitney $U$, $p = 0.19$). (b) Per-subject scatter of number of walking bouts against median bout duration. Point size is scaled by 6MWD. Subjects with more bouts and longer median bout durations tend to have longer 6MWD. Axes use log scales to accommodate the wide range of bout counts and durations.\relax }{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Supplementary Figure S2. Per-subject bout-duration distribution. Each box shows one subject, sorted by median bout duration. POMS subjects are in the top row (red) and healthy subjects are in the bottom row (blue). The visualization shows the within-subject spread of bout durations and how the spread varies between groups.\relax }}{20}{figure.caption.16}\protected@file@percent }
\newlabel{fig:supp_boxplots}{{9}{20}{Supplementary Figure S2. Per-subject bout-duration distribution. Each box shows one subject, sorted by median bout duration. POMS subjects are in the top row (red) and healthy subjects are in the bottom row (blue). The visualization shows the within-subject spread of bout durations and how the spread varies between groups.\relax }{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Supplementary Figure S3. Sensitivity of home 6MWD prediction MAE to the minimum walking-bout duration threshold. At each threshold (10, 30, 60, 120, 240 s) the cached per-bout features are filtered, re-aggregated, combined with the 29 whole-recording activity features, and fed to the headline Bout+Act-Top20+Demo pipeline (Ridge $\alpha =20$, leave-one-out cross-validation). Error bars are 95\% percentile bootstrap confidence intervals (B = 2000). The 10\,s threshold yields the best MAE of 56.0\,m; stricter thresholds reduce the number of usable bouts (mean bouts per subject drop from 1{,}454 at 10\,s to 11 at 240\,s) and at 240\,s leave 9 of 101 subjects with zero bouts, degrading MAE to 65.5\,m.\relax }}{21}{figure.caption.17}\protected@file@percent }
\newlabel{fig:supp_bout_threshold}{{10}{21}{Supplementary Figure S3. Sensitivity of home 6MWD prediction MAE to the minimum walking-bout duration threshold. At each threshold (10, 30, 60, 120, 240 s) the cached per-bout features are filtered, re-aggregated, combined with the 29 whole-recording activity features, and fed to the headline Bout+Act-Top20+Demo pipeline (Ridge $\alpha =20$, leave-one-out cross-validation). Error bars are 95\% percentile bootstrap confidence intervals (B = 2000). The 10\,s threshold yields the best MAE of 56.0\,m; stricter thresholds reduce the number of usable bouts (mean bouts per subject drop from 1{,}454 at 10\,s to 11 at 240\,s) and at 240\,s leave 9 of 101 subjects with zero bouts, degrading MAE to 65.5\,m.\relax }{figure.caption.17}{}}
