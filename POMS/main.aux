\newlabel{sec:rq3}{{4.3}{9}{RQ3: Correlation Between Clinic and Home Features}{subsection.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Home walking-bout characteristics by cohort ($n=101$). Left: violin plot of the longest sustained bout per subject. Middle: scatter of number of bouts against longest bout duration. Right: pooled bout-duration survival curve with 95\% bootstrap CI. POMS subjects cluster at shorter bout durations and have fewer long sustained bouts.\relax }}{10}{figure.caption.5}\protected@file@percent }
\newlabel{fig:bout_overview}{{2}{10}{Home walking-bout characteristics by cohort ($n=101$). Left: violin plot of the longest sustained bout per subject. Middle: scatter of number of bouts against longest bout duration. Right: pooled bout-duration survival curve with 95\% bootstrap CI. POMS subjects cluster at shorter bout durations and have fewer long sustained bouts.\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Spearman correlations between accelerometry features and 6MWD in the full cohort (All), the POMS subgroup, and the healthy subgroup. Clinic features (left) and home features (right) are shown side by side. Gait intensity and tempo features dominate the clinic side. Home correlations are smaller but directionally consistent. Significance stars use raw $p$-values: *$p<0.05$, **$p<0.01$, ***$p<0.001$.\relax }}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:corr_6mwd}{{3}{10}{Spearman correlations between accelerometry features and 6MWD in the full cohort (All), the POMS subgroup, and the healthy subgroup. Clinic features (left) and home features (right) are shown side by side. Gait intensity and tempo features dominate the clinic side. Home correlations are smaller but directionally consistent. Significance stars use raw $p$-values: *$p<0.05$, **$p<0.01$, ***$p<0.001$.\relax }{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Clinic-to-home correlation for five matched Gait features. Rows are the clinic feature. Columns are the 90th-percentile home counterpart. Each panel shows one cohort group (All, POMS, Healthy). Diagonal cells are the direct matches; off-diagonal cells show cross-feature spillover. The densest cluster of significant cells lies at the 90th-percentile column, meaning the supervised 6MWT tracks the upper decile of free-living walking rather than the median.\relax }}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:clinic_home_corr}{{4}{11}{Clinic-to-home correlation for five matched Gait features. Rows are the clinic feature. Columns are the 90th-percentile home counterpart. Each panel shows one cohort group (All, POMS, Healthy). Diagonal cells are the direct matches; off-diagonal cells show cross-feature spillover. The densest cluster of significant cells lies at the 90th-percentile column, meaning the supervised 6MWT tracks the upper decile of free-living walking rather than the median.\relax }{figure.caption.7}{}}
