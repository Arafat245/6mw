\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the study pipeline. Participants completed a clinic-supervised 6MWT with a hip-worn accelerometer and a 7-day free-living monitoring period with a hip-worn accelerometer. Four feature categories were extracted from both settings. Ridge regression with leave-one-out cross-validation was used for clinic prediction, while PLS domain adaptation mapped home features into the clinic feature space for home-based prediction.\relax }}{4}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{4}{Overview of the study pipeline. Participants completed a clinic-supervised 6MWT with a hip-worn accelerometer and a 7-day free-living monitoring period with a hip-worn accelerometer. Four feature categories were extracted from both settings. Ridge regression with leave-one-out cross-validation was used for clinic prediction, while PLS domain adaptation mapped home features into the clinic feature space for home-based prediction.\relax }{figure.caption.1}{}}
