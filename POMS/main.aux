\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Spearman correlations between clinic accelerometry features and clinical scores in the POMS subgroup ($n=38$). Clinical scores: EDSS, MFIS Total, MFIS Physical (Phys), MFIS Cognitive (Cog), MFIS Psychosocial (Psych), BDI, and POMS disease duration (Dur). CWT harmonic ratio correlates positively with MFIS Physical ($\rho =0.42$).\relax }}{13}{figure.caption.8}\protected@file@percent }
\newlabel{fig:clin_corr_clinic}{{3}{13}{Spearman correlations between clinic accelerometry features and clinical scores in the POMS subgroup ($n=38$). Clinical scores: EDSS, MFIS Total, MFIS Physical (Phys), MFIS Cognitive (Cog), MFIS Psychosocial (Psych), BDI, and POMS disease duration (Dur). CWT harmonic ratio correlates positively with MFIS Physical ($\rho =0.42$).\relax }{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Spearman correlations between home accelerometry features and clinical scores in the POMS subgroup ($n=38$). Home features show attenuated but directionally consistent correlations compared to clinic features.\relax }}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:clin_corr_home}{{4}{13}{Spearman correlations between home accelerometry features and clinical scores in the POMS subgroup ($n=38$). Home features show attenuated but directionally consistent correlations compared to clinic features.\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Predicted vs.\ actual 6MWD for the best clinic model (Gait+CWT+WalkSway+Demo, $R^2=0.806$) and the best home model (PLS(Gait)+Demo(5), $R^2=0.519$). Points are colored by cohort (POMS vs.\ Healthy). The dashed line indicates perfect prediction.\relax }}{14}{figure.caption.10}\protected@file@percent }
\newlabel{fig:pred_vs_actual}{{5}{14}{Predicted vs.\ actual 6MWD for the best clinic model (Gait+CWT+WalkSway+Demo, $R^2=0.806$) and the best home model (PLS(Gait)+Demo(5), $R^2=0.519$). Points are colored by cohort (POMS vs.\ Healthy). The dashed line indicates perfect prediction.\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Bland-Altman plots showing agreement between predicted and actual 6MWD for clinic (left) and home (right) models. Solid lines indicate mean bias; dashed lines indicate $\pm $1.96 SD limits of agreement. Low bias is observed in both settings.\relax }}{14}{figure.caption.11}\protected@file@percent }
\newlabel{fig:bland_altman}{{6}{14}{Bland-Altman plots showing agreement between predicted and actual 6MWD for clinic (left) and home (right) models. Solid lines indicate mean bias; dashed lines indicate $\pm $1.96 SD limits of agreement. Low bias is observed in both settings.\relax }{figure.caption.11}{}}
