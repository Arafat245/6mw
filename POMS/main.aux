\newlabel{tab:group_diff}{{5}{12}{Top accelerometry features differentiating POMS from healthy controls by setting, ranked by $|d|$. $p$-values are BH-corrected. Features with $p_{\text {adj}}<0.05$ and $|d|>0.5$ shown.\relax }{table.caption.7}{}}
