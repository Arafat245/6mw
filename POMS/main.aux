\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Features that differ significantly between POMS and healthy controls in each setting. POMS and Healthy columns show mean\nobreakspace  {}$\pm $\nobreakspace  {}SD in the native feature units. Rows are ordered by $|d|$ within each setting. Negative $d$ means POMS is lower than healthy. Significance levels use BH-adjusted $p$-values: *$p<0.05$, **$p<0.01$, ***$p<0.001$.\relax }}{9}{table.caption.4}\protected@file@percent }
\newlabel{tab:mshealthy}{{3}{9}{Features that differ significantly between POMS and healthy controls in each setting. POMS and Healthy columns show mean~$\pm $~SD in the native feature units. Rows are ordered by $|d|$ within each setting. Negative $d$ means POMS is lower than healthy. Significance levels use BH-adjusted $p$-values: *$p<0.05$, **$p<0.01$, ***$p<0.001$.\relax }{table.caption.4}{}}
