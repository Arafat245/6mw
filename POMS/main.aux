\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Prediction performance ($R^2$) for all feature sets across clinic and home settings. Ridge regression ($\alpha =10$) with leave-one-out cross-validation. PLS models use 2-component domain adaptation from home to clinic feature space. Best results per setting are in \textbf  {bold}.\relax }}{10}{table.caption.4}\protected@file@percent }
\newlabel{tab:results}{{3}{10}{Prediction performance ($R^2$) for all feature sets across clinic and home settings. Ridge regression ($\alpha =10$) with leave-one-out cross-validation. PLS models use 2-component domain adaptation from home to clinic feature space. Best results per setting are in \textbf {bold}.\relax }{table.caption.4}{}}
