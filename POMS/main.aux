\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Feature Correlations with 6MWD}{10}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Spearman correlations between accelerometry features and 6MWD, stratified by cohort (All, POMS, Healthy) and setting (Clinic, Home). Only features with $|\rho | > 0.3$ in at least one condition are shown. Gait intensity features (ENMO, VT RMS, jerk) show the strongest positive correlations; CWT and WalkSway features show moderate associations.\relax }}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:corr_heatmap}{{2}{11}{Spearman correlations between accelerometry features and 6MWD, stratified by cohort (All, POMS, Healthy) and setting (Clinic, Home). Only features with $|\rho | > 0.3$ in at least one condition are shown. Gait intensity features (ENMO, VT RMS, jerk) show the strongest positive correlations; CWT and WalkSway features show moderate associations.\relax }{figure.caption.6}{}}
